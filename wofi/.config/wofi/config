# Matte Black Wofi Configuration

# Window
width=600
height=400
location=center
anchor=center
halign=center
valign=center

# Font
font=JetBrains Mono Nerd Font 12

# Colors (MatBlack theme)
background-color=#0a0a0aff
text-color=#d0d0d0ff
border-color=#1a1a1aff
border-size=1

# Prompt
prompt=Run
prompt-color=#909090ff
prompt-text-color=#d0d0d0ff
input-color=#d0d0d0ff
input-background=#121212ff
input-border-color=#303030ff

# Selected item
selected-background=#1f1f1fff
selected-text-color=#e0e0e0ff

# Match highlighting
match-color=#a0c0e0ff

# Scrollbar
scrollbar-width=6
scrollbar-color=#303030ff
scrollbar-handle-color=#404040ff

# Icons
show-icons=true
icon-size=28
icon-theme=Papirus-Dark

# Behavior
allow-images=true
allow-markup=true
insensitive=true
fuzzy=true
normal-window=false

# Layout
columns=1
lines=12
spacing=4
padding=16
margin=8

# Separator
separator-color=#202020ff

# DRUN mode specific
drun-display-format={name}
drun-print-format={desktop_id}
drun-icon-fallback=application-x-executable
drun-categories=true

# Window mode
window-format={title} — {app}
window-icon=true

# File mode
file-print-path=true