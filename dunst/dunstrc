[global]
    monitor = 0
    follow = none
    indicate_hidden = yes
    notification_limit = 20

    width = 320
    height = (0, 300)
    origin = top-right
    offset = (16, 50)
    scale = 0

    notification_limit = 20

    progress_bar = true
    progress_bar_height = 6
    progress_bar_frame_width = 0
    progress_bar_min_width = 200
    progress_bar_max_width = 300
    progress_bar_corner_radius = 0

    corner_radius = 0
    corners = top-right, top-left, bottom-right, bottom-left

    transparency = 0
    separator_height = 2
    padding = 16
    horizontal_padding = 16
    text_icon_padding = 12
    frame_width = 0
    frame_color = "#000000"

    separator_color = auto

    sort = yes
    sticky_history = yes
    history_length = 15

    idle_threshold = 0

    font = "CaskaydiaCove Nerd Font 10"
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    word_wrap = false
    ellipsize = middle
    ignore_newline = false
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    enable_posix_regex = true

    enable_recursive_icon_lookup = true
    icon_theme = "breeze-dark, Adwaita"
    icon_position = left
    min_icon_size = 24
    max_icon_size = 48
    icon_corner_radius = 8

    show_age_threshold = 60

    dmenu = /usr/bin/dmenu -p dunst:
    browser = /usr/bin/xdg-open
    always_run_script = true

    title = Dunst
    class = Dunst

    ignore_dbusclose = false
    force_xwayland = false

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false
    pause_on_mouse_over = false

[urgency_low]
    background = "#000000"
    foreground = "#666666"
    frame_color = "#222222"
    timeout = 5
    default_icon = dialog-information

[urgency_normal]
    background = "#000000"
    foreground = "#aaaaaa"
    frame_color = "#333333"
    timeout = 8
    default_icon = dialog-information

[urgency_critical]
    background = "#000000"
    foreground = "#ff4444"
    frame_color = "#ff0000"
    timeout = 0
    default_icon = dialog-warning

[spotify]
    appname = "spotify"
    icon_position = left
    format = "<b>%s</b>"

[volume]
    appname = "Volume"
    format = "<b>Volume</b>\n%b"

[brightness]
    appname = "Brightness"
    format = "<b>Brightness</b>\n%b"

[network]
    appname = "Network"
    format = "<b>%s</b>\n%b"

[clipboard]
    appname = "Clipboard"
    format = "<b>Clipboard</b>\n%b"

[screenshot]
    summary = ".*screenshot.*"
    format = "<b>Screenshot</b>\n%b"
    timeout = 3
